     d = frame([
         (9, 10, 8, 9), (9, 11, 8, 9), (9, 15, 8, 9),
-        (9, 11, 8, 9), (9, 16, 8, 9),  # confirmation bar also wicks above
-        (9, 16, 8, 9),                 # only this later bar may sweep it
